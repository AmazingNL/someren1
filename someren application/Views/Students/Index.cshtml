@model List<someren_application.Models.Students>
@{
    ViewData["Title"] = "Students";
}

<div class="text-center">
    <h1 class="display-4">Students</h1>
    <p>All students are listed here</p>
</div>

<table class="table">
    <thead>
        <tr>
            <th>StudentNumber</th>
            <th>FirstName</th>
            <th>LastName</th>
            <th>Phone Number</th>
            <th>StudentClass</th>
            <th>Room Number</th>

            <th>
                <div>
                    <div class="w-75 btn-group" role="group">
                        <a asp-controller="Students" asp-action="Create" class="btn btn-primary mx-2 ">
                            Add Student
                        </a>
                    </div>
                </div>
            </th>
        </tr>
    </thead>
    <tbody>
        @{
            foreach (Students student in Model)
            {

                <tr>
                    <td>@student.StudentNumber</td>
                    <td>@student.FirstName</td>
                    <td>@student.LastName</td>
                    <td>@student.PhoneNumber</td>
                    <td>@student.StudentClass</td>
                    <td>@student.Rooms[0].RoomNumber</td>
                    
                    <td>
                        <div class="w-75 btn-group" role="group">
                            <a asp-controller="Students" asp-action="Edit" asp-route-studentId="@student.StudentId" class="btn btn-primary mx-2 ">
                                <i class="bi bi-pencil-square"></i>EDIT
                            </a>
                            <a asp-controller="Students" asp-action="Delete" asp-route-studentId="@student.StudentId" class="btn btn-danger mx-2 ">
                                <i class="bi bi-trash"></i>DELETE
                            </a>
                        </div>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
