@{
    ViewData["Title"] = "Students";
}

<div class="text-center">
    <h1 class="display-4">Students</h1>
    <p>All students are listed here</p>
</div>

<table class="table">
    <thead>
        <tr>
            <th>FirstName</th>
            <th>LastName</th>
            <th>Telephone</th>
            <th>EmailAddress</th>
            <th>
                <div>
                    <div class="w-75 btn-group" role="group">
                        <a asp-controller="Users" asp-action="Create" class="btn btn-primary mx-2 ">
                            ADD Student
                        </a>
                    </div>
            </th>
        </tr>
    </thead>
    <tbody>
        @{
            foreach (var student in Model)
            {
                <tr>
                    <td>@student.FirstName</td>
                    <td>@student.LastName</td>
                    <td>@student.Telephone</td>
                    <td>@student.EmailAddress</td>
                    <td>
                        <div class="w-75 btn-group" role="group">
                            <a asp-controller="Users" asp-action="Edit" asp-route-id="@student.StudentId" class="btn btn-primary mx-2 ">
                                <i class="bi bi-pencil-square"></i>EDIT
                            </a>
                            <a asp-controller="Users" asp-action="Delete" asp-route-id="@student.StudentId" class="btn btn-danger mx-2 ">
                                <i class="bi bi-trash"></i>DELETE
                            </a>
                        </div>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
