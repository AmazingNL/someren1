@model someren_application.Models.Room

<form method="post" asp-controller="Room" asp-action="Create" onsubmit="alert('Form submitted!');">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">
                Create Room
            </h2>
            <hr/>
        </div>
        <div class="mb-3 row">
            <label asp-for="Building" class="p-0"></label>
            <input asp-for="Building" class="form-control" />
            <span asp-validation-for="Building" class="text-danger"></span>
        </div>
        <div class="mb-3 row">
            <label asp-for="RoomNumber" class="p-0"></label>
            <input asp-for="RoomNumber" class="form-control" />
            <span asp-validation-for="RoomNumber" class="text-danger"></span>
        </div>
        <div class="mb-3 row">
            <label asp-for="Capacity" class="p-0"></label>
            <input asp-for="Capacity" class="form-control" />
            <span asp-validation-for="Capacity" class="text-danger"></span>
        </div>
        <div class="mb-3 row">
            <label asp-for="RoomType" class="p-0"></label>
            <input asp-for="RoomType" class="form-control" />
            <span asp-validation-for="RoomType" class="text-danger"></span>
        </div>
        <div class="row">
            <div class="col-6 col-mid-3">
                <button type="submit" class="btn btn-primary form-control">Create</button>
            </div>
            <div class="col col-mid-3">
                <a asp-controller="Room" asp-action="Index" class="btn btn-outline-secondary border form-control">
                    Back To User
                </a>
            </div>
        </div>
    </div>
</form>
