@model List<someren_application.Models.Room>
@{
    ViewData["Title"] = "Room";
}
<div class="text-center">
    <h1 class="display-4">Room</h1>
    <p>Available Rooms</p>
</div>
<div>
    <table class="table">
        <thead>
            <tr>
                <th>Room Number</th>
                <th>Room Type</th>
                <th>Capacity</th>             
                <th>Building</th>
                <th>
                    <div class="w-75 btn-group" role="group">
                        <form action="Room/Filter" method="POST">
                            <label for="Capacity">Enter a number:</label>
                            <input type="number" id="Capacity" name="Capacity" required>
                            <button type="submit">Search</button>
                        </form>
                        <a asp-controller="Room" asp-action="Create" class="btn btn-primary mx-2 ">
                            ADD Room
                        </a>
                    </div>
                </th>
            </tr>
        </thead>
        <tbody>
            @{
                foreach (Room room in Model)
                {
                    <tr>
                        <td>@room.RoomNumber</td>
                        <td>@room.RoomType</td>
                        <td>@room.Capacity</td>
                        <td>@room.Building</td>
                        <td>
                            <div class="w-75 btn-group" role="group">
                                <a asp-controller="Room" asp-action="Edit" asp-route-id="@room.RoomId" class="btn btn-primary mx-2 link-dark">
                                    <i class="bi bi-pencil-square"></i>EDIT
                                </a>
                                <a asp-controller="Room" asp-action="Delete" asp-route-id="@room.RoomId" class="btn btn-danger mx-2 link-primary">
                                    <i class="bi bi-trash"></i>DELETE
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>

    </table>
</div>
