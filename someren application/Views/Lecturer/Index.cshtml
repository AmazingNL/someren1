
@model List<someren_application.Models.Lecturer>
@{
    ViewData["Title"] = "Lecturer";

}
<div class="text-center">
    <h1 class="display-4">Lecturer</h1>
    <p>All Lecturers are listed here</p>
</div>

<table class="table">
    <thead>
        <tr>
            <th>FirstName</th>
            <th>LastName</th>
            <th>PhoneNumber</th>
            <th>Age</th>
            <th>RoomID</th>

            <th>
                <div>
                    <div class="w-75 btn-group" role="group">
                        <a asp-controller="Lecturer" asp-action="Create" class="btn btn-primary mx-2 ">
                            Add Lecturer
                        </a>
                    </div>
                </div>
            </th>
        </tr>
    </thead>
    <tbody>
        @{
            foreach (Lecturer lecturer in Model)
            {
                <tr>
                    <td>@lecturer.FirstName</td>
                    <td>@lecturer.LastName</td>
                    <td>@lecturer.PhoneNumber</td>
                    <td>@lecturer.Age</td>
                    <td>@lecturer.RoomID</td>

                    <td>
                        <div class="w-75 btn-group" role="group">
                            <a asp-controller="Lecturer" asp-action="Edit" asp-route-id="@lecturer.LecturerID" class="btn btn-primary mx-2 ">
                                <i class="bi bi-pencil-square"></i>EDIT
                            </a>
                            <a asp-controller="Lecturer" asp-action="Delete" asp-route-id="@lecturer.LecturerID" class="btn btn-danger mx-2 ">
                                <i class="bi bi-trash"></i>DELETE
                            </a>
                        </div>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
