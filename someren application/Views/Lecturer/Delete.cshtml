@model someren_application.Models.Lecturer

@{
    ViewData["Title"] = "Delete Lecturer";
}

<form method="post" asp-controller="Lecturer" asp-action="Delete">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">
                Delete Lecturer
            </h2>
            <hr />
        </div>

        <!-- Hidden LecturerID -->
        <input type="hidden" asp-for="LecturerID" />

        <!-- Display Read-Only Details -->
        <div class="mb-3 row">
            <label class="p-0">Lecturer ID</label>
            <input asp-for="LecturerID" class="form-control" disabled />
        </div>

        <div class="mb-3 row">
            <label class="p-0">First Name</label>
            <input asp-for="FirstName" class="form-control" disabled />
        </div>

        <div class="mb-3 row">
            <label class="p-0">Last Name</label>
            <input asp-for="LastName" class="form-control" disabled />
        </div>

        <div class="mb-3 row">
            <label class="p-0">Phone Number</label>
            <input asp-for="PhoneNumber" class="form-control" disabled />
        </div>

        <div class="mb-3 row">
            <label class="p-0">Age</label>
            <input asp-for="Age" class="form-control" disabled />
        </div>

        <div class="mb-3 row">
            <label class="p-0">Room ID</label>
            <input asp-for="RoomID" class="form-control" disabled />
        </div>

        <div class="row">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-danger form-control">Confirm Delete</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Lecturer" asp-action="Index" class="btn btn-outline-secondary border form-control">
                    Cancel
                </a>
            </div>
        </div>
    </div>
</form>