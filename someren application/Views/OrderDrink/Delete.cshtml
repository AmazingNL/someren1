@model someren_application.Models.OrderDrinks

@{
    ViewData["Title"] = "Delete Drinks";
}

<div>
    <h1>Delete Drinks</h1>

    <div class="form-group py-2">
        <label>ORDER ID:</label>
        <p>@Model.OrderId</p> <!-- Display Drink Name -->
    </div>
    <div class="form-group py-2">
        <label>DRINK NAME:</label>
        <p>@Model.Drinks[0].DrinkName</p> <!-- Display Alcoholic / Non-Alcoholic -->
    </div>
    <div class="form-group py-2">
        <label>STUDENT NUMBER:</label>
        <p>@Model.Students[0].StudentNumber</p> <!-- Display Vat Rate -->
    </div>
    <div class="row">
        <div class="col-3">
            <!-- Delete Confirmation Form with POST request -->
            <form asp-controller="OrderDrink" asp-action="Delete" method="post">
                <input type="hidden" asp-for="OrderId" />
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
        <div class="col-3">
            <a asp-controller="OrderDrink" asp-action="Index" class="btn btn-outline-secondary border form-control">
                Back To Drinks
            </a>
        </div>
    </div>
</div>
