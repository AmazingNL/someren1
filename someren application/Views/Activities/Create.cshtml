@model someren_application.Models.ActivitiesModel

<form method="post" asp-controller="Activities" asp-action="Create" onsubmit="alert('Form submitted!');">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">
                Create Activity
            </h2>
            <hr />
        </div>
        <div class="mb-3 row">
            <label asp-for="ActivityName" class="p-0"></label>
            <input asp-for="ActivityName" class="form-control" />
            <span asp-validation-for="ActivityName" class="text-danger"></span>
        </div>
        <div class="mb-3 row">
            <label asp-for="TimeSlot" class="p-0"></label>
            <input asp-for="TimeSlot" class="form-control" />
            <span asp-validation-for="TimeSlot" class="text-danger"></span>
        </div>
        <div class="row">
            <div class="col-6 col-mid-3">
                <button type="submit" class="btn btn-primary form-control">Create</button>
            </div>
            <div class="col col-mid-3">
                <a asp-controller="Activities" asp-action="Index" class="btn btn-outline-secondary border form-control">
                    Back To Activity
                </a>
            </div>
        </div>
    </div>
</form>

