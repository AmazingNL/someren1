@model someren_application.Models.Drinks

@{
    ViewData["Title"] = "Edit Drinks";
}

<form method="post" asp-controller="Drinks" asp-action="Edit" onsubmit="alert('Form submitted!');">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">
                EDIT DRINKS
            </h2>
            <hr />
        </div>
        <input hidden asp-for="DrinkId" />
        <div class="mb-3 row">
            <label asp-for="DrinkName" class="p-0"></label>
            <input asp-for="DrinkName" class="form-control" />
            <span asp-validation-for="DrinkName" class="text-danger"></span>
        </div>
        <div class="mb-3 row">
            <label asp-for="IsAlcoholic" class="p-0"></label>
            <div>
                <input type="radio" asp-for="IsAlcoholic" value="true" /> Alcoholic
                <input type="radio" asp-for="IsAlcoholic" value="false" /> Non-Alcoholic
            </div>
            <span asp-validation-for="IsAlcoholic" class="text-danger"></span>
        </div>
        <div class="mb-3 row">
            <label asp-for="VatRate" class="p-0"></label>
            <input asp-for="VatRate" class="form-control" />
            <span asp-validation-for="VatRate" class="text-danger"></span>
        </div>
        <div class="row">
            <div class="col-6 col-mid-3">
                <button type="submit" class="btn btn-primary form-control">Edit</button>
            </div>
            <div class="col col-mid-3">
                <a asp-controller="Drinks" asp-action="Index" class="btn btn-outline-secondary border form-control">
                    Back To Drinks
                </a>
            </div>
        </div>
    </div>
</form>
