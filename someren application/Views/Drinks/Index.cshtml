@model List<someren_application.Models.Drinks>
@{
    ViewData["Title"] = "Drinks";
}
<div class="text-center">
    <h1 class="display-4">Drinks</h1>
    <p>Available Drinks</p>
</div>
<div>
    <table class="table">
        <thead>
            <tr>
                <th>Drink Name</th>
                <th>Alcoholic / Non-Alcoholic</th>
                <th>Vat Rate</th>
                <th>Quantity</th>
                <th>
                    <div class="w-75 btn-group" role="group">
                        <a asp-controller="Drinks" asp-action="Create" class="btn btn-primary mx-2 ">
                            ADD Drink
                        </a>
                    </div>
                </th>
            </tr>
        </thead>
        <tbody>
            @{
                foreach (Drinks drinks in Model)
                {
                    <tr>
                        <td>@drinks.DrinkName</td>
                        <td>@drinks.IsAlcoholic</td>
                        <td>@drinks.VatRate</td>
                        <td>@drinks.Quantity</td>
                        <td>
                            <div class="w-75 btn-group" role="group">
                                <a asp-controller="Drinks" asp-action="Edit" asp-route-drinkId="@drinks.DrinkId" class="btn btn-primary mx-2 link-dark">
                                    <i class="bi bi-pencil-square"></i>EDIT
                                </a>
                                <a asp-controller="Drinks" asp-action="Delete" asp-route-drinkId="@drinks.DrinkId" class="btn btn-danger mx-2 link-primary">
                                    <i class="bi bi-trash"></i>DELETE
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>

    </table>
</div>

